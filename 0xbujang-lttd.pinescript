// table.cell(myTable, 1, row, str.tostring(final_score[1], format.mintick), bgcolor=color.new(final_score_color,70), text_color=color.new(binary_color, 10), text_halign=text.align_center, text_size=table_text_size)

// === ICHIMOKU ===

// Inputs for Ichimoku periods
tenkan_period = input.int(9, "Tenkan Period", group = ichimoku_group)
kijun_period = input.int(26, "Kijun Period", group = ichimoku_group)
senkou_b_period = input.int(52, "Senkou B Period", group = ichimoku_group)
displacement = kijun_period  // Standard displacement

price_high =  high
price_low =  low

// Core Ichimoku Calculations
tenkan = (ta.highest(price_high, tenkan_period) + ta.lowest(price_low, tenkan_period)) / 2
kijun = (ta.highest(price_high, kijun_period) + ta.lowest(price_low, kijun_period)) / 2
senkou_a = (tenkan + kijun) / 2
senkou_b = (ta.highest(price_high, senkou_b_period) + ta.lowest(price_low, senkou_b_period)) / 2
chikou = close

// Plot Core Lines
plot(show_ichimoku ? tenkan : na, "Tenkan", color=#2962FF, force_overlay = true)
plot(show_ichimoku ? kijun : na, "Kijun", color=#B71C1C, force_overlay = true)
p1 = plot(show_ichimoku ? senkou_a : na, "Senkou A", color=#6A1B9A, offset=displacement, force_overlay = true)
p2 = plot(show_ichimoku ? senkou_b : na, "Senkou B", color=#C2185B, offset=displacement, force_overlay = true)
fill(p1, p2, color=senkou_a > senkou_b ? color.new(#6A1B9A, 80) : color.new(#C2185B, 80), title="Cloud")
plot(show_ichimoku ? chikou : na, "Chikou", color=#43A047, offset=-displacement+1, force_overlay = true)



