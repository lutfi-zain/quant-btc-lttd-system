show_long   = input.bool(true,"Long Signal", group = strategy_settings)
bool show_cobra = input.bool(true, "Show Cobra Dashboard", group = strategy_settings)

disp_ind = input.string ("Strategy" , title = "Display Curve" , tooltip = "Choose which data you would like to display", options=["Strategy", "Equity", "Open Profit", "Gross Profit", "Net Profit", "None"], group = strategy_settings)
pos_table = input.string("Bottom Right", "Table Position", options = ["Top Left", "Middle Left", "Bottom Left", "Top Right", "Middle Right", "Bottom Right", "Top Center", "Bottom Center"], group = strategy_settings)
type_table = input.string("Simple", "Table Type", options = ["Full", "Simple", "None"], group = strategy_settings)

