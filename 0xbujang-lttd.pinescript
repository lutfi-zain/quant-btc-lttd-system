// ======================================== Start of Indicator 10 ============================
indicator10_group = 'Indicator 10 - '
//Input's
i10_smoothK = input.int(21, title="%K Smoothing", minval=1, group = indicator10_group + "Stochastic Settings")
i10_periodD = input.int(5, title="%D Smoothing", minval=1, group = indicator10_group + "Stochastic Settings")
i10_Score = input.string("k > 50","Score Stoch by", ["k > 50", "k > d", "d > 50"], group = indicator10_group + "Calculation Type")
i10_a = input.int(1, "Start Length",  group = indicator10_group + "STOCH ForLoop Settings")
i10_b = input.int(129, "End Length",   group = indicator10_group + "STOCH ForLoop Settings")
i10_maType = input.string("SMA", "MA Type", ["EMA", "SMA", "WMA","VWMA","DEMA","TMA"], group = indicator10_group + "STOCH ForLoop Settings", inline = "M")
i10_c = input.int(23,  "MA Length",   group = indicator10_group + "STOCH ForLoop Settings", inline = "M")


i10_sigmode = input.string("Thresholds Crossing", "Signal Mode", options = ["Fast", "Slow", "Thresholds Crossing", "Fast Threshold"], group = indicator10_group + "Signal Settings")
i10_longth =  input.float(-0.9,   "Long Threshold", step = 0.01, group = indicator10_group + "Signal Settings", inline = "T")
i10_shortth = input.float(0.95, "Short Threshold", step = 0.01, group = indicator10_group + "Signal Settings", inline = "T")
i10_fastth =  input.float(0.1,  "Fast Threshold",   step = 0.01, group = indicator10_group + "Signal Settings")

i10_colup = input.color(color.lime,"Bull Color",  group = indicator10_group + "Visualisation")
i10_coldn = input.color(color.fuchsia  ,"Bull Color",  group = indicator10_group + "Visualisation")
i10_barcol = input.bool(true,         "Color Bars?", group = indicator10_group + "Visualisation")

i10_barconfirm = input.bool(false, "Wait for bar close for Alert?", group = indicator10_group + "Alert Settings")

// Function's to calculate an array of STOCH values over a range of lengths
STOCH(a, b, c) =>
    var T = 0.0
    var SignalArray = array.new_float(b - a + 1, 0.0)
    for x = 0 to (b - a)
        len = a + x

        k = ta.sma(ta.stoch(close, high, low, len), i10_smoothK)
        d = ta.sma(k, i10_periodD)
        if i10_Score == "k > 50"
            if k > 50
                T := 1
            if k < 50
                T := -1
        else if i10_Score == "k > d"
            if k > d
                T := 1
            if k < d
                T := -1
        else
            if d > 50
                T := 1
            if d < 50
                T := -1

        trend = T == 1 ? 1 : -1
        array.set(SignalArray, x, trend)
    Avg = array.avg(SignalArray)
    float MA = switch i10_maType
        "EMA" =>   ta.ema(Avg,    c)
        "SMA" =>   ta.sma(Avg,    c)
        "WMA" =>   ta.wma(Avg,    c)
        "VWMA" =>  ta.vwma(Avg,   c)
        "DEMA" =>  ta.dema(Avg,  c)
        "TMA" =>   ta.trima(Avg,  c)
        => 
            runtime.error("No matching MA type found.")
            float(na)
    [SignalArray, Avg, MA]

//}

//Calculation's

[SignalArray,Avg,MA] = STOCH(i10_a, i10_b, i10_c)

col1 = MA > 0 ? i10_colup : i10_coldn
var color col2 = na
if MA > MA[1] or MA > 0.99
    col2 := i10_colup
if MA < MA[1] or MA < -0.99
    col2 := i10_coldn
var color col3 = na
if ta.crossover(MA,i10_longth)
    col3 := i10_colup
if ta.crossunder(MA,i10_shortth)
    col3 := i10_coldn
var color col4 = na 
if (MA > MA[1] + i10_fastth)
    col4 := i10_colup
if (MA < MA[1] - i10_fastth)
    col4 := i10_coldn

color i10_col = na
if i10_sigmode == "Slow"
    i10_col := col1
if i10_sigmode == "Fast"
    i10_col := col2
if i10_sigmode == "Thresholds Crossing"
    i10_col := col3
if i10_sigmode == "Fast Threshold"
    i10_col := col4
else
    na



//Alert's
var int alertsignal = na
if i10_col == i10_colup
    alertsignal := 1
if i10_col == i10_coldn
    alertsignal := -1
Long  = ta.crossover(alertsignal,  0)
Short = ta.crossunder(alertsignal, 0)

var indicator10_score = 0
i10_trend_color = i10_col

if barstate.isconfirmed
    indicator10_score := alertsignal

// ======================================== End of Indicator 10 ============================

// ======================================== Start of Indicator 11 ==========================

indicator11_group = 'Indicator 11 '

i11_vwma_length = input.int(145, title="VWMA Length", minval=1)
i11_atr_length = input.int(50, title="ATR Length", minval=1)
i11_trend_enter = input.float(1.5, step=0.1, title="Trend Enter", minval=0.1)
i11_trend_exit = input.float(1.0, step=0.1, title="Trend Exit", minval=0.1)

// Signal Options
i11_enable_alerts = input.bool(false, "Enable Alerts", group=indicator11_group + "Signals")

// Color Inputs 
i11_col_strong = input.color(color.lime, "Strong Trend", group=indicator11_group + "Visual Style", inline="colors")
i11_col_weak = input.color(color.rgb(255, 0, 0), "Weak Trend", group=indicator11_group + "Visual Style", inline="colors")
i11_col_neutral = input.color(color.gray, "Neutral", group=indicator11_group + "Visual Style", inline="colors")

// Enhanced Visual Options
i11_show_colored_candles = input.bool(true, "Show Colored Candles", group=indicator11_group + "Visual Style")
i11_show_gradient_background = input.bool(true, "Show Gradient Background", group=indicator11_group + "Visual Style")
i11_line_thickness = input.int(2, "Line Thickness", minval=1, maxval=5, group=indicator11_group + "Visual Style")

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════
// DYNAMIC GRADIENT FUNCTION
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════

// Dynamic gradient function based on trend thresholds
f_dynamic_gradient(value, enter_threshold, exit_threshold) =>
    abs_value = math.abs(value)
    is_positive = value >= 0
    
    if abs_value >= enter_threshold
        is_positive ? color.lime : color.rgb(180, 0, 0)
    else if abs_value >= exit_threshold
        if is_positive
            intensity = (abs_value - exit_threshold) / (enter_threshold - exit_threshold)
            color.rgb(int(120 + 135 * intensity), int(200 + 55 * intensity), int(80))
        else
            intensity = (abs_value - exit_threshold) / (enter_threshold - exit_threshold)
            color.rgb(int(200 + intensity * -20), int(20 + intensity * -20), int(20))
    else
        if value > 0
            intensity = abs_value / exit_threshold
            color.rgb(int(180 + 60 * intensity), int(140 + 60 * intensity), int(60 + 20 * intensity))
        else if value < 0
            intensity = abs_value / exit_threshold  
            color.rgb(int(240), int(80 + 40 * (1 - intensity)), int(60 - 20 * intensity))
        else
            color.gray

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════

// 1. Volume Weighted Moving Average (VWMA)
i11_vwma = ta.vwma(close, i11_vwma_length)

// 2. Average True Range (ATR)
i11_atr = ta.atr(i11_atr_length)

// 3. Trend Strength Calculation 
i11_price_distance_raw = (close - i11_vwma) / i11_atr  
i11_trend_strength = math.max(-2.0, math.min(2.0, i11_price_distance_raw))  

// 4. Additional Statistical Measures
i11_trend_momentum_raw = ta.change(i11_trend_strength, 3)  
i11_trend_momentum = math.max(-2.0, math.min(2.0, i11_trend_momentum_raw))  
i11_trend_smooth = ta.ema(i11_trend_strength, 5)       

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════
// SIGNAL GENERATION LOGIC
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════

// Previous values for signal detection
i11_prev_trend_strength = i11_trend_strength[1]
i11_abs_trend_strength = math.abs(i11_trend_strength)
i11_prev_abs_trend_strength = math.abs(i11_prev_trend_strength)

// Signal conditions
i11_bull_entry_signal = i11_trend_strength > i11_trend_enter and i11_prev_trend_strength <= i11_trend_enter
i11_bear_entry_signal = i11_trend_strength < -i11_trend_enter and i11_prev_trend_strength >= -i11_trend_enter

i11_bull_exit_signal = i11_trend_strength < i11_trend_exit and i11_prev_trend_strength >= i11_trend_exit and i11_prev_trend_strength > 0
i11_bear_exit_signal = i11_trend_strength > -i11_trend_exit and i11_prev_trend_strength <= -i11_trend_exit and i11_prev_trend_strength < 0

// Signal states for tracking
var bool i11_in_bull_trend = false
var bool i11_in_bear_trend = false

// Update trend states
if i11_bull_entry_signal
    i11_in_bull_trend := true
    i11_in_bear_trend := false
else if i11_bear_entry_signal
    i11_in_bear_trend := true
    i11_in_bull_trend := false
else if i11_bull_exit_signal and i11_in_bull_trend
    i11_in_bull_trend := false
else if i11_bear_exit_signal and i11_in_bear_trend
    i11_in_bear_trend := false

// Combined signal logic for cleaner detection
any_entry_signal = i11_bull_entry_signal or i11_bear_entry_signal
any_exit_signal = i11_bull_exit_signal or i11_bear_exit_signal

// Current trend state
current_trend_state = i11_in_bull_trend ? "BULL TREND" : i11_in_bear_trend ? "BEAR TREND" : "NO TREND"

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════
// DYNAMIC COLOR CALCULATIONS 
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════════

// Main trend strength color 
trend_color = f_dynamic_gradient(i11_trend_strength, i11_trend_enter, i11_trend_exit)

// Momentum color using dynamic gradient
momentum_color = f_dynamic_gradient(i11_trend_momentum, i11_trend_enter, i11_trend_exit)

// Background color gradient
bg_intensity = math.abs(i11_trend_strength) / 2.0  
bg_color = i11_show_gradient_background ? 
     color.new(color.from_gradient(bg_intensity, 0, 1, i11_col_neutral, 
     i11_trend_strength > 0 ? i11_col_strong : i11_col_weak), 95) : na

// Candle coloring based on trend strength using dynamic gradient
color candle_color = na
if i11_show_colored_candles
    candle_color := f_dynamic_gradient(i11_trend_strength, i11_trend_enter, i11_trend_exit)



var indicator11_score = 0

i11_long = ta.crossover(i11_trend_strength, i11_trend_enter)
i11_short = ta.crossunder(i11_trend_strength, -i11_trend_exit)

if barstate.isconfirmed
    if i11_long
        indicator11_score := 1
    if i11_short
        indicator11_score := -1


// ======================================== End of Indicator 11 ============================

// ======================================== Start of Indicator 12 ==========================
// --------------------------------------------------------------------------------------------------------------------}
// 📌 𝙐𝙎𝙀𝙍 𝙄𝙉𝙋𝙐𝙏𝙎
// --------------------------------------------------------------------------------------------------------------------{
int   i12_length              = input(121, "Length")

color i12_color_up            = input.color(#31ca45, "Up")
color i12_color_dn            = input.color(color.rgb(255, 113, 18), "Down")

bool i12_candles              = input.bool(true, "CandleStick Color")

var i12_direction = int(na)
var i12_count = 0

// --------------------------------------------------------------------------------------------------------------------}
// 📌 𝙄𝙉𝘿𝙄𝘾𝘼𝙏𝙊𝙍 𝘾𝘼𝙇𝘾𝙐𝙇𝘼𝙏𝙄𝙊𝙉𝙎
// --------------------------------------------------------------------------------------------------------------------{

savitzky_golay_filter_w_15_vectors(source) =>
    float sum            = 0.0
    float polynomial     = 0.0
    float[] coefficients = array.new<float>(16)
    // Predefined 15 coefficients
    for i = -4 to 4
        coefficients.set(i + 4, i) // from -4 to 5
        if i == 4
            for j = 5 to -4
                for g = 8 to 15 
                    coefficients.set(g, j) // from 5 to -4

    // Calculate normalization factor as the sum of absolute values of coefficients
    float norm_factor = coefficients.sum()

    // Loop through coefficients and calculate the weighted sum
    for i = 0 to coefficients.size()-1
        sum := sum + coefficients.get(i) * source[i]

    // Calculate the smoothed value
    for i = 1 to i12_length-1
        polynomial := math.sum(sum / norm_factor, i) / i

    polynomial

// Apply the filter to close prices
i12_basis = savitzky_golay_filter_w_15_vectors(close)


i12_distance = ta.sma(high-low, 100) * 2

i12_h_band = i12_basis + i12_distance
i12_l_band = i12_basis - i12_distance

i12_prevLowerBand = nz(i12_l_band[1])
i12_prevUpperBand = nz(i12_h_band[1])

i12_l_band := i12_l_band > i12_prevLowerBand or close[1] < i12_prevLowerBand ? i12_l_band : i12_prevLowerBand
i12_h_band := i12_h_band < i12_prevUpperBand or close[1] > i12_prevUpperBand ? i12_h_band : i12_prevUpperBand

if barstate.isconfirmed
    if close > i12_h_band
        i12_direction := 1 
    if close < i12_l_band
        i12_direction := -1 

i12_change = i12_direction != i12_direction[1]

i12_t_color = i12_basis > i12_basis[2] ? i12_color_up : i12_color_dn
i12_t_band = i12_direction > 0 ? i12_l_band : i12_h_band

if i12_direction == i12_direction[1]
    i12_count += 1
if i12_change
    i12_count := 0

indicator12_score = i12_direction

// --------------------------------------------------------------------------------------------------------------------}
// 📌 𝙑𝙄𝙎𝙐𝘼𝙇𝙄𝙕𝘼𝙏𝙄𝙊𝙉
// --------------------------------------------------------------------------------------------------------------------{


candl_col =  (i12_direction > 0 ? i12_color_up : i12_color_dn) 


// --------------------------------------------------------------------------------------------------------------------}



// ======================================== End of Indicator 12 ============================


// ======================================== Start of OnChain 1 ==========================


