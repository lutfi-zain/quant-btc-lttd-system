// 1. Format Waktu menjadi Tanggal (YYYY-MM-DD)
string current_date = str.format_time(time, "yyyy-MM-dd", syminfo.timezone)

// 2. Cetak Header HANYA di bar pertama
if barstate.isfirst
    // Menambahkan kolom baru di bagian akhir header
