indicator8_group = "Indicator 8 - "

// Design Setup
i8_ColMode = input.string("Strategy", title = "Color Mode", group = "Visual | QuantEdgeB", options = ["Strategy", "Solar","Warm","Cool","Classic","Magic"])
i8_LABEL   = input.bool(false,"Long/Cash Signal Lable" , group = "Visual | QuantEdgeB")


[i8_color_up, i8_color_dn, i8_color_nu] = switch i8_ColMode
    "Strategy"=> [color.rgb(23, 191, 238), color.rgb(103, 2, 2),color.gray]
    "Solar"   => [color.rgb(43, 56, 247), #ee6728,color.gray]
    "Warm"    => [#ffbb00, #770737,color.gray]
    "Cool"    => [#0aede9, color.rgb(12, 16, 218),color.gray]
    "Classic" => [#04f7e7, color.maroon,color.gray]
    "Magic"   => [color.rgb(114, 44, 246), color.rgb(214, 245, 42),color.gray]


// Color Palette
color i8_col_up1     = i8_color_up
color i8_col_up2     = color.new(i8_color_up, 30)
color i8_col_up3     = color.new(i8_color_up, 100)
color i8_col_dn1     = i8_color_dn
color i8_col_dn2     = color.new(i8_color_dn, 30)
color i8_col_nu2     = color.new(i8_color_dn, 70)

//###############################################################################################################################################################################################################################################//
// DEMA Function
F_DEMA(SRC, LEN) =>
    E1 = ta.ema(SRC, LEN)
    E2 = ta.ema(E1, LEN)

    DEMA = 2 * E1 - E2

    DEMA

// SuperTrend Function
F_SupTrend(DEMA,len,len_atr,mult_up,mult_dn,SD_Filter) =>
    lowerATR = ta.percentile_nearest_rank(DEMA,len,25) - ta.atr(len_atr) * mult_up
    upperATR = ta.percentile_nearest_rank(DEMA,len,75) + ta.atr(len_atr) * mult_dn

    previous_LATR = nz(lowerATR[1])
    previous_UATR = nz(upperATR[1])

    lowerATR := lowerATR > previous_LATR or close[1] < previous_LATR ? lowerATR : previous_LATR
    upperATR := upperATR < previous_UATR or close[1] > previous_UATR ? upperATR : previous_UATR
    int ST_Direction = na
    float Super_Trend = na
   
    if na(SD_Filter[1])
        ST_Direction := 1
        ST_Direction
    else if Super_Trend[1] == previous_UATR
        ST_Direction := close > upperATR ? -1 : 1
        ST_Direction
    else
        ST_Direction := close < lowerATR ? 1 : -1
        ST_Direction

    Super_Trend := ST_Direction == -1 ? lowerATR : upperATR

    [Super_Trend, ST_Direction]

//###############################################################################################################################################################################################################################################//
// DEMA
i8_len_dema      = input.int(251,"Dema Length", group = "DEMA")
i8_len_perc      = input.int(15, "Percentile Filter", group = "DEMA")
i8_filtered_src  = ta.percentile_nearest_rank(close,i8_len_perc , 50)


DEMA_Base = F_DEMA(i8_filtered_src, i8_len_dema)

//###############################################################################################################################################################################################################################################//
// ATR 
i8_len_atr = input.int(200, "ATR Length", group = "Volatility")
i8_mult_up = input.float(0.5,"Long Multiplier",step = 0.1, group = "Volatility")
i8_mult_dn = input.float(1.2,"Short Multiplier",step = 0.1, group = "Volatility")

//###############################################################################################################################################################################################################################################//
//Final Supertrend 
i8_len_demaST = input.int(20,"DEMA Supertrend Length",group = "SuperTrend")
i8_len_p      = input.int(20,"Percenteil Filter length",group = "SuperTrend")
i8_len_SD     = input.int(30, "SD Length", group = "Standard Deviation")

DEMA       = F_DEMA(DEMA_Base,i8_len_demaST)
SD_Filter  = ta.stdev(i8_filtered_src, i8_len_SD)

[Super_Trend, ST_Direction] = F_SupTrend(DEMA, i8_len_p,i8_len_atr, i8_mult_up, i8_mult_dn,SD_Filter)

//###############################################################################################################################################################################################################################################//
//Final Signal 
i8_Long_C  = ta.crossunder(ST_Direction, 0)
i8_Short_C = ta.crossover(ST_Direction, 0)

var i8_QB = 0

if i8_Long_C and not i8_Short_C
    i8_QB := 1
    i8_QB

if i8_Short_C
    i8_QB := -1
    i8_QB

i8_trend_color = i8_QB == 1 ? i8_color_up : i8_QB == -1 ? i8_color_dn : i8_color_nu

indicator8_score = i8_QB

// Plot Labels
if i8_QB == -1 and i8_QB[1] == -1 and  i8_QB[2] == 1 and i8_LABEL// Only plot when the signal changes
    label.new(x=bar_index, y= Super_Trend, text= "𝓢𝓱𝓸𝓻𝓽" , color=  i8_color_dn, style=  label.style_label_down  ,textcolor=color.white, size=size.tiny)

if i8_QB == 1 and i8_QB[1] == 1 and  i8_QB[2] == -1 and i8_LABEL// Only plot when the signal changes
    label.new(x=bar_index, y= Super_Trend, text= "𝓛𝓸𝓷𝓰" , color=  i8_color_up, style=  label.style_label_up  ,textcolor=color.white, size=size.tiny)


// ======================================== End of Indicator 8 ============================


// ======================================== Start of Indicator 9 ============================


indicator9_group = "Indicator 9 - "

//Inverted SD Dema RSI | viResearch
i9_sublen = input.int(70,"dema len", group = indicator9_group+ "Inverted SD Dema RSI | viResearch")
i9_sublen_2 = input.int(41,"sd len", group = indicator9_group+ "Inverted SD Dema RSI | viResearch")
i9_len = input.int(47,"rsi len", group = indicator9_group+ "Inverted SD Dema RSI | viResearch")
