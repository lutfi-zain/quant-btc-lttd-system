final_group_visual = "=== Final Setting - Visual"
bullcolor = input.color(#ffdbac, "Bullish Color", group=final_group_visual)
weak_bullcolor = input.color(#b89f7e, "Bullish Color", group=final_group_visual)
bearcolor = input.color(#96a4d3, "Bearish Color", group=final_group_visual)
weak_bearcolor = input.color(#67708f, "Bearish Color", group=final_group_visual)
neutral_color = input.color(#ffffff, "Bearish Color", group=final_group_visual)

var final_trend_color = color.gray
var final_score_color = color.gray

final_group_strat = "=== Final Setting - Strategy"
bull_threshold = input(0.95, 'bull threshold', group = final_group_strat) 
weak_bull_threshold = input(0.75, 'weak bull threshold', group = final_group_strat) 
weak_bear_threshold = input(-0.85, 'weak bearthreshold', group = final_group_strat)
bear_threshold = input(-0.95, 'bear threshold', group = final_group_strat) 

limit_backtest_time = input.bool(true,"Limit Backtest Time", group = strategy_settings)
backtest_start_at = input.time(defval = timestamp('01 Jan 2018 00:00 +0700'), title="Backtest Start At", group = strategy_settings)

final_long_condition  = ta.crossover(final_score, final_long_threshold)
final_short_condition = ta.crossunder(final_score, final_short_threshold)

half_long_condition  = ta.crossover(final_score, half_long_threshold)
half_short_condition = ta.crossunder(final_score, half_short_threshold)


// if (limit_backtest_time ? time > backtest_start_at : true) and barstate.isconfirmed
//     // Logic Entry
//     // Half Long (50% equity)
//     if half_long_condition and strategy.position_size == 0  // Hanya masuk jika flat
//         half_qty = math.round(strategy.equity * 0.5 / close)
//         strategy.entry("Long", strategy.long, qty=half_qty, comment="50% Long")

//     // Final Long (tambah 50% equity)
//     if final_long_condition and strategy.position_size > 0  // Hanya tambah jika sudah long
//         half_qty = math.round(strategy.equity * 0.5 / close)
//         strategy.entry("Long", strategy.long, qty=half_qty, comment = "100% Long")

//     if half_short_condition and strategy.opentrades > 0
//         strategy.close("Long", "50% Cash", qty_percent = 50)

//     // Exit (close full position on short conditions)
//     if (half_short_condition or final_short_condition) and strategy.position_size > 0
//         strategy.close("Long", comment="50Cash", qty_percent = 100)

if barstate.isconfirmed
    if final_long_condition
        if (limit_backtest_time ? time > backtest_start_at : true)
            strategy.entry("Buy", strategy.long, comment = "Buy")
            final_trend_color := bullcolor

    // if half_short_condition and strategy.opentrades > 0
    //     strategy.close("Buy", "50% Cash", qty_percent = 50)

    if final_short_condition
        strategy.close("Buy", "Sell", qty_percent = 100)
        final_trend_color := bearcolor



f_get_final_color(score) =>
     score >= bull_threshold       ? bullcolor :
     score >= weak_bull_threshold ? weak_bullcolor :
     score > weak_bear_threshold  ? neutral_color :
     score >= bear_threshold      ? weak_bearcolor :
     bearcolor

f_calc_trend_strength(score) =>
     score >= bull_threshold ? 1.0 : 
     score >= weak_bull_threshold ? (score - weak_bull_threshold) / (bull_threshold - weak_bull_threshold) : 
     score > weak_bear_threshold ? 0.0 : 
     score >= bear_threshold? (score - weak_bear_threshold) / (bear_threshold - weak_bear_threshold) : -1.0

f_calc_trend_state(score) =>
     score >= bull_threshold       ? "BULL" :
     score >= weak_bull_threshold ? "WEAK BULL" :
     score > weak_bear_threshold  ? "NEUTRAL" :
     score >= bear_threshold      ? "WEAK BEAR" :
     "BEAR"

// f_calc_trend_state(score) =>
//      score >= bull_threshold ? "Bull" : 
//      score >= weak_bull_threshold ? "Weak Bull" : 
//      score > weak_bear_threshold ? "Weak Bear" : "Bear" 


final_score_color := f_get_final_color(final_score)

plotcandle(open, high, low, close, color=final_score_color, wickcolor=final_score_color, bordercolor=final_score_color, force_overlay=true, title="Final Chart Candle", display = display.none)
plot_final = plot(final_score, "LTTD Final Score", final_trend_color,2,plot.style_line)

plot(final_score, "LTTD Final Trend Strength", color.new(final_score_color,40),1,plot.style_histogram, editable = true)



