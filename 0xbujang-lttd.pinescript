     )
// ───────────────────────────────
// Fungsi konversi tanggal chart ke string yyyy-MM-dd
F1_getDateString() =>
    F1_yyyy = str.tostring(year)
    F1_mm   = str.tostring(month, "00")
    F1_dd   = str.tostring(dayofmonth, "00")
    F1_yyyy + "-" + F1_mm + "-" + F1_dd

// ───────────────────────────────
// Fungsi cari value dari pasangan "tanggal|value"
F1_getValueForDate(F1_dateStr, data) =>
    float F1_result = na
    for F1_i = 0 to array.size(data) - 1
        F1_pair = array.get(data, F1_i)
        F1_sep  = str.split(F1_pair, "|")
        F1_d    = array.get(F1_sep, 0)
        F1_v    = str.tonumber(array.get(F1_sep, 1))
        if F1_d == F1_dateStr
            F1_result := F1_v
    F1_result

// ───────────────────────────────
// Hitung score
F1_todayStr = F1_getDateString()
F1_valToday = F1_getValueForDate(F1_todayStr, F1_data)

var F1_score = 0
var F1_score_color = color.gray

F1_Long_Condition = F1_valToday == 1
F1_Short_Condition = F1_valToday == -1

if barstate.isconfirmed
    if F1_Long_Condition 
        F1_score := 1
        F1_score_color := F1_bullcolor
    if F1_Short_Condition 
        F1_score := -1
        F1_score_color := F1_bearcolor

