i9_rsi = ta.rsi(i9_dema, i9_len)

i9_stdev = ta.stdev(i9_dema , i9_sublen_2)
i9_u = i9_dema + i9_stdev
i9_d = i9_dema - i9_stdev

i9_supl = close > i9_d
i9_sups = close < i9_u

i9_Threshold_L = input.int( 50,title = "Threshold uptrend", step = 1, group = indicator9_group+ "Threshold")
i9_Threshold_S = input.int( 49,title = "Threshold downtrend" , step = 1, group = indicator9_group+ "Threshold") 

i9_L = i9_rsi > i9_Threshold_L and not i9_sups
i9_S = i9_rsi < i9_Threshold_S 

var i9_vii = 0

if i9_L and not i9_S 
	i9_vii := 1

if i9_S 
	i9_vii := -1


indicator9_score = i9_vii
i9_trend_color = indicator9_score ==  1 ?  color.rgb(0, 255, 187) :  color.rgb(255, 0, 157)


