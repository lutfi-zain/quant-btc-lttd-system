if show_cobra
    cobra.cobraTable(type_table, pos_table)

import Bikelife76/MajorCobraMetrics2025/2 as cobra

table_settings_group = "📊 Table Settings"

binary_color = final_score < 0 ? bearcolor : bullcolor

// === INPUT FOR TABLE SETTINGS ===
table_position = input.string("bottom_right", "Table Position", options=[
     "top_left", "top_center", "top_right",
     "middle_left", "middle_center", "middle_right",
     "bottom_left", "bottom_center", "bottom_right"
 ], group=table_settings_group)

table_text_size = input.string("normal", "Text Size", options=["tiny", "small", "normal", "large", "huge"], group=table_settings_group)
force_overlay_setting = input.bool(true, "Force Overlay", group=table_settings_group)




// === POSITION MAPPING FUNCTION ===
f_get_position(pos_str) =>
     pos_str == "top_left"       ? position.top_left :
     pos_str == "top_center"     ? position.top_center :
     pos_str == "top_right"      ? position.top_right :
     pos_str == "middle_left"    ? position.middle_left :
     pos_str == "middle_center"  ? position.middle_center :
     pos_str == "middle_right"   ? position.middle_right :
     pos_str == "bottom_left"    ? position.bottom_left :
     pos_str == "bottom_center"  ? position.bottom_center :
     pos_str == "bottom_right"   ? position.bottom_right :
     position.top_right

// === CREATE & CONFIGURE TABLE ===
table myTable = table.new(f_get_position(table_position), 3, 23, border_color = bullcolor, frame_width = 1, border_width=1, frame_color=bullcolor, force_overlay = true)
table myTableSummary = table.new(position.bottom_center, 7, 23, border_color = bullcolor, frame_width = 1, border_width=1, frame_color=bullcolor, force_overlay = true)

// === CLEAR TABLE ===
if bar_index == 0
    table.clear(myTable, 0, 0, 2, 22)
    table.clear(myTableSummary, 0, 0, 2, 22)

// === HEADER ROW ===
table.cell(myTableSummary, 0, 0, text="0xBujang - Long Term Trend Direction", text_color=final_score_color, bgcolor=color.new(bullcolor,70), text_halign=text.align_center, text_size=table_text_size)
table.merge_cells(myTableSummary, 0,0,3,0)

table.cell(myTableSummary, 0, 1, "Score", text_size=table_text_size, text_color = final_trend_color, bgcolor=color.new(bullcolor,70))
table.cell(myTableSummary, 1, 1, str.tostring(final_score[1], format.mintick), text_size=table_text_size, text_color = final_trend_color,width = 4)

table.cell(myTableSummary, 2, 1, "ROC", text_size=table_text_size, text_color = final_trend_color, bgcolor=color.new(bullcolor,70))
table.cell(myTableSummary, 3, 1, str.tostring(math.round(final_score[1],2) - math.round(final_score[2],2), format.mintick), text_size=table_text_size, text_color = final_trend_color)

table.cell(myTableSummary, 0, 2, f_calc_trend_state(final_score[1]), text_size=table_text_size, text_color = final_trend_color, bgcolor=color.new(final_trend_color,70))
table.merge_cells(myTableSummary, 0,2,3,2)

table.cell(myTable, 0, 0, text="Indicator", text_color=final_score_color, bgcolor=color.new(bullcolor,70), text_halign=text.align_center, text_size=table_text_size)
table.cell(myTable, 1, 0, text="Score", text_color=final_score_color, bgcolor=color.new(bullcolor,70), text_halign=text.align_center, text_size=table_text_size)

// === ROW POPULATION ===
int row = 1

f_add_row(name, score, enabled, row) =>
    textcolor = score > 0 ? bullcolor : bearcolor
    if enabled
        table.cell(myTable, 0, row, name, text_size=table_text_size, text_color = textcolor)
        table.cell(myTable, 1, row, str.tostring(score, format.mintick), text_size=table_text_size, text_color = textcolor)
        row + 1
    else
        row


// Add enabled indicators
if barstate.islast
    row := f_add_row("Indicator 1",  indicator1_score,  use_indicator1, row)
    row := f_add_row("Indicator 2",  indicator2_score,  use_indicator2, row)
    row := f_add_row("Indicator 3",  indicator3_score,  use_indicator3, row)
    row := f_add_row("Indicator 4",  indicator4_score,  use_indicator4, row)
    row := f_add_row("Indicator 5",  indicator5_score,  use_indicator5, row)
    row := f_add_row("Indicator 6",  indicator6_score,  use_indicator6, row)
    row := f_add_row("Indicator 7",  indicator7_score,  use_indicator7, row)
    row := f_add_row("Indicator 8",  indicator8_score,  use_indicator8, row)
    row := f_add_row("Indicator 9",  indicator9_score,  use_indicator9, row)
    row := f_add_row("Indicator 10", indicator10_score, use_indicator10, row)
    row := f_add_row("Indicator 11", indicator11_score, use_indicator11, row)
    row := f_add_row("Indicator 12", indicator12_score, use_indicator12, row)
    row := f_add_row("On-Chain 1", F1_score, use_onchain1, row)
    row := f_add_row("On-Chain 2", F2_score, use_onchain2, row)
    row := f_add_row("On-Chain 3", F3_score, use_onchain3, row)
    row := f_add_row("On-Chain 4", F4_score, use_onchain4, row)


// === FINAL SCORE ===
