//@version=6
strategy(
 "0xBujang - LTTD", 
 overlay=false, default_qty_type = strategy.percent_of_equity, default_qty_value = 100, initial_capital = 1000000000, calc_on_order_fills = true, calc_on_every_tick = true, margin_long = 0, margin_short = 0, slippage = 1)

string ichimoku_group = "=== Ichimoku ==="
show_ichimoku = input.bool(true, "Show Ichimoku", group = ichimoku_group)

var string strategy_settings  = "════════ Strategy Settings ════════"
final_long_threshold = input.float(-0.4,"Final Long Threshold", group=strategy_settings)
final_short_threshold = input.float(0.4,"Final Short Threshold", group=strategy_settings)

half_long_threshold = input.float(-0.2, "Half Long Threshold", group=strategy_settings)
half_short_threshold = input.float(0.55, "Half Short Threshold", group=strategy_settings)

use_indicator_group = " Use Indicator ==="
use_indicator1 = input.bool(true, "1", inline="row1", group=strategy_settings + use_indicator_group)
use_indicator2 = input.bool(true, "2", inline="row1", group=strategy_settings + use_indicator_group)
use_indicator3 = input.bool(true, "3", inline="row1", group=strategy_settings + use_indicator_group)
use_indicator4 = input.bool(true, "4", inline="row1", group=strategy_settings + use_indicator_group)
use_indicator5 = input.bool(true, "5", inline="row2", group=strategy_settings + use_indicator_group)
use_indicator6 = input.bool(true, "6", inline="row2", group=strategy_settings + use_indicator_group)
use_indicator7 = input.bool(true, "7", inline="row2", group=strategy_settings + use_indicator_group)
use_indicator8 = input.bool(true, "8", inline="row2", group=strategy_settings + use_indicator_group)
use_indicator9 = input.bool(true, "9", inline="row3", group=strategy_settings + use_indicator_group)
use_indicator10 = input.bool(true, "10", inline="row3", group=strategy_settings + use_indicator_group)
use_indicator11 = input.bool(true, "11", inline="row3", group=strategy_settings + use_indicator_group)
use_indicator12 = input.bool(true, "12", inline="row3", group=strategy_settings + use_indicator_group)
use_onchain1 = input.bool(true, "F1", inline="row4", group=strategy_settings + use_indicator_group)
use_onchain2 = input.bool(true, "F2", inline="row4", group=strategy_settings + use_indicator_group)
use_onchain3 = input.bool(true, "F3", inline="row4", group=strategy_settings + use_indicator_group)
use_onchain4 = input.bool(true, "F4", inline="row4", group=strategy_settings + use_indicator_group)





// ======================================== Start of Indicator 1 ============================

string kalman_group = "Indicator 1 - "

// Kalman Filter parameters
series float        pricesource          = input.source(ohlc4, "Kalman Price Source", group = kalman_group + "Calculation")
simple float        processNoise         = input.float(0.75, title="Process Noise", step = 0.01, group = kalman_group + "Calculation")
simple float        measurementNoise     = input.float(205, title="Measurement Noise", group = kalman_group + "Calculation")
simple int          N                    = input.int(3, title="Filter Order", minval=1, group = kalman_group + "Calculation")
simple int          rsiPeriod            = input.int(250, "RSI Calculation Period", group = kalman_group + "Calculation")
simple bool         smooth               = input.bool(false, "Smooth RSI?", group = kalman_group + "Smoothing")
string   modeSwitch                        = input.string(
                                         'Ema', 
                                         title='Smoothing Type:', 
                                         options=[
                                                     'Hma', 
                                                     'Thma', 
                                                     'Ehma', 
                                                     'SMA', 
                                                     'Ema', 
                                                     'Wma',
                                                     'Tema', 
                                                     'Vwma'
                                                     ]
                                         , 
                                         group = kalman_group + "Smoothing", 
                                         inline = "3"
                                         )
simple int          smoothlen            = input.int(7, "Smoothing Period:", group = kalman_group + "Smoothing")
simple bool         showkalman           = input.bool(true, "Show Kalman RSI?", group = kalman_group + "UI Settings")
simple bool         paintCandles         = input.bool(true, "Paint candles according to Trend? (RSI Midline Crossover)", group = kalman_group + "UI Settings")

var float[] stateEstimate = array.new_float(N, na)
var float[] errorCovariance = array.new_float(N, 100.0)

f_init(series float pricesource) =>
    if na(array.get(stateEstimate, 0))
        for i = 0 to N-1
            array.set(stateEstimate, i, pricesource)
            array.set(errorCovariance, i, 1.0)

f_kalman(series float pricesource) =>
    // Prediction Step
    predictedStateEstimate = array.new_float(N)
    predictedErrorCovariance = array.new_float(N)
    for i = 0 to N-1
        array.set(predictedStateEstimate, i, array.get(stateEstimate, i)) // Simplified prediction
        array.set(predictedErrorCovariance, i, array.get(errorCovariance, i) + processNoise)
    
    kalmanGain = array.new_float(N)
    for i = 0 to N-1
        kg = array.get(predictedErrorCovariance, i) / (array.get(predictedErrorCovariance, i) + measurementNoise)
        array.set(kalmanGain, i, kg)
        array.set(stateEstimate, i, array.get(predictedStateEstimate, i) + kg * (pricesource - array.get(predictedStateEstimate, i)))
        array.set(errorCovariance, i, (1 - kg) * array.get(predictedErrorCovariance, i))
    
    array.get(stateEstimate, 0)

f_init(pricesource)
kalmanFilteredPrice = f_kalman(pricesource)

// Conditional Trend

rsi = ta.rsi(kalmanFilteredPrice, rsiPeriod)

import TradingView/ta/7 as ta
// Exponential Hull Moving Average Function
EHMA(_src, _length) =>
    ta.ema(2 * ta.ema(_src, _length / 2) - ta.ema(_src, _length), math.round(math.sqrt(_length)))
// Triple Hull Moving Average Function    
THMA(_src, _length) =>
    ta.wma(ta.wma(_src, _length / 3) * 3 - ta.wma(_src, _length / 2) - ta.wma(_src, _length), _length)
// Smoothing MA Switch
Mode(modeSwitch, src, len) =>
                 modeSwitch == 'Hma' ? ta.hma(src, len) 
                 : modeSwitch == 'Ehma' ? EHMA(src, len) 
                 : modeSwitch == 'Thma' ? THMA(src, len / 2) 
                 : modeSwitch == 'SMA' ? ta.sma(src, len) 
                 : modeSwitch == 'Ema' ? ta.ema(src, len) 
                 : modeSwitch == 'Wma' ? ta.wma(src, len)
                 : modeSwitch == 'Tema' ? ta.tema(src, len)
                 : modeSwitch == 'Vwma' ? ta.vwma(src, len) 
                 : na

// Fisher Smoothing 
if smooth == true
    rsi:=Mode(modeSwitch, rsi, smoothlen)


// Normalize the oscillator
lowest = ta.lowest(rsi, 100)
highest = ta.highest(rsi, 100)
rsi := (rsi - lowest) / (highest - lowest) - 0.5


posroc = rsi > rsi[1]
negroc = rsi < rsi[1]
var color col = #4caf50
if rsi > 0 and posroc
    col := #00ff08
if rsi > 0 and negroc
    col := #00bbd4
if rsi < 0 and negroc
    col := #ff0000
if rsi < 0 and posroc
    col := #771515

var indicator1_score = 0
indicator1_color = color.gray

if barstate.isconfirmed
    indicator1_score := rsi >= 0 ? 1 : -1
    indicator1_color := indicator1_score == 1 ? color.green : color.red


// ======================================== End of Indicator 1 ============================


// ======================================== Start of Indicator 2 ============================

zenith_group = "Indicator 2 - "

EMA_src = ta.ema(ohlc4,14)

i2_length = input(80, title='Linear Regression Length', group = zenith_group)
stdv_length = input(75, title='Standard Deviation Length', group = zenith_group)
vwap_length = input(129, title='VWAP Length', group = zenith_group)
smaLength = input(400, title='SMA Length') , group = zenith_group 
// src = input(ohlc4, title='Source')
i2_src = EMA_src

// Calculate Linear Regression
linregValue = ta.linreg(i2_src, i2_length, 0)

// Calculate Deviation from Linear Regression
deviation = i2_src - linregValue

// Calculate Standard Deviation of Deviations
stdevValue = ta.stdev(deviation, stdv_length)

// Calculate VWAP
vwapValue = ta.vwma(i2_src, vwap_length)

// Calculate VWAP Divergence
vwapDivergence = i2_src - vwapValue

// Calculate Dynamic Multiplier
dynamicMultiplier = ta.stdev(close, stdv_length)

// Combine VWAP Divergence with Standard Deviation using Dynamic Multiplier
combinedValue = stdevValue * (1 + vwapDivergence / dynamicMultiplier)

// Calculate the Centered Oscillator by subtracting SMA
centeredOscillator = combinedValue - ta.sma(combinedValue, smaLength)

colorG = centeredOscillator > 0 ? centeredOscillator > centeredOscillator[1] ? color.new(color.aqua, 50) : color.new(color.teal, 50) : centeredOscillator < centeredOscillator[1] ? color.new(color.fuchsia, 50) : color.new(color.purple, 50)


var indicator2_score = 0
indicator2_color = color.gray

if barstate.isconfirmed
    indicator2_score := centeredOscillator >= 0 ? 1 : -1
    indicator2_color := indicator2_score == 1 ? color.green : color.red



// ======================================== End of Indicator 2 ============================


// ======================================== Start of Indicator 3 ==========================
supertrend_group = "Indicator 3 - "

// Input Groups
gr1 = supertrend_group + "Range Settings"
ma1 = supertrend_group + "Moving Average Settings"

// Range Settings
i3_p          = input.int  (18, title="Length", minval=1 , group=gr1)
i3_t          = input.int  (47, title="Lookback Alpha", group=gr1, minval=1)
i3_d          = input.int  (82, title="Lookback Beta", group=gr1, minval=1)
i3_s          = input.float(0.98, step=0.01, title="Multiplier Alpha", group=gr1, minval=0.01)
i3_x          = input.float(0.98, step=0.01, title="Multiplier Beta", group=gr1, minval=0.01)
i3_sou        = input.source(ohlc4,title = 'Source', group=gr1)

// Calculations for Range


hgh        = ta.highest(i3_sou, i3_p)
ss         = hgh * i3_s
dd         = hgh * i3_x
avgsd        = math.avg(ss[i3_t], dd[i3_d])
useavg     = input.bool(false, title="Use Average Range", group=gr1)

// Moving Average Settings
i3_ma_type    = input.string("EMA", title="Type", options=["SMA", "EMA", "SMMA", "WMA", "VWMA", "TEMA", "DEMA", "LSMA", "HMA", "ALMA"], group=ma1)
i3_len        = input.int(60, title="Length", minval=1, group=ma1)
i3_src        = input(close, title="Source", group=ma1)

// Moving Average Calculation Function
function_ma(src, len, type) =>
    switch type
        "TEMA" =>
            ema1 = ta.ema(src, len)
            ema2 = ta.ema(ema1, len)
            ema3 = ta.ema(ema2, len)
            3 * (ema1 - ema2) + ema3
        "DEMA" =>
            ema1 = ta.ema(src, len)
            ema2 = ta.ema(ema1, len)
            2 * ema1 - ema2
        "SMA" => ta.sma(src, len)
        "EMA" => ta.ema(src, len)
        "SMMA" => ta.rma(src, len)
        "WMA" => ta.wma(src, len)
        "LSMA" => ta.linreg(src, len, 0)
        "HMA" => ta.wma(2 * ta.wma(src, len / 2) - ta.wma(src, len), math.floor(math.sqrt(len)))
        "ALMA" => ta.alma(src, len, 0.85, 6)
        "VWMA" => ta.vwma(src, len)
// Apply Moving Average
ma           = function_ma(i3_src, i3_len, i3_ma_type)

var color cc = na 
var int g    = 0
var int g2   = 0
var int h    = 0

if ma < close 
    h  := 1 
if ma > close 
    h  := -1 
if close > avgsd 
    g  := 1
if close < avgsd 
    g  := -1
if close > ss[i3_t] 
    g2 := 1
if close < dd[i3_d]
    g2 := -1

i3_score           = useavg?math.avg(g,h) : math.avg(g2,h)
i3_long_condition  = ta.crossover(i3_score,0)
i3_short_condition = ta.crossunder(i3_score,0)

cup= input.color(#00a444,title = "Bullish Color")
cdn= input.color(#df0000f3,title = "Bearish Color")


var int indicator3_score = 0

if barstate.isconfirmed
    //Color Conditions 
    if i3_long_condition
        cc := cup
        indicator3_score := 1
    if i3_short_condition
        cc:= cdn
        indicator3_score := -1
    

// ======================================== End of Indicator 3 ============================


// ======================================== Start of Indicator 4 ============================
FDI_Group = "Indicator 4 - "

// ─── Boolean Inputs to Select Oscillators ───────────────────────────────
useRSI = input.bool(true, title="Use RSI", group=FDI_Group + "RSI")
useCCI = input.bool(true, title="Use CCI", group=FDI_Group + "CCI")
useCMO = input.bool(false, title="Use CMO", group=FDI_Group + "CMO")
useMFI = input.bool(false, title="Use MFI", group=FDI_Group + "MFI")


// ─── Relative Strength Index (RSI) ────────────────────────────────
RSI_length  = input.int(55, minval=1, title="RSI Length", group=FDI_Group + "RSI")
RSI_src     = input.source(ohlc4, "RSI Source", group=FDI_Group + "RSI")
RSI_FDI_chop_LongThreshold  = input.float(55, title="RSI FDI Chop Long Threshold", group=FDI_Group + "RSI",minval=50,tooltip = "Setting to 50 disables filtering on the upside")
RSI_FDI_chop_ShortThreshold = input.float(45, title="RSI FDI Chop Short Threshold", group=FDI_Group + "RSI",maxval=50,tooltip = "Setting to 50 disables filtering on the downside")


// ─── Commodity Channel Index (CCI) ────────────────────────────────
CCI_length  = input.int(55, minval=1, title="CCI Length", group=FDI_Group + "CCI")
CCI_src     = input.source(ohlc4, "CCI Source", group=FDI_Group + "CCI")
CCI_FDI_chop_LongThreshold  = input.float(100, title="CCI FDI Chop Long Threshold", group=FDI_Group + "CCI",minval=0,tooltip = "Setting to 0 disables filtering on the upside")
CCI_FDI_chop_ShortThreshold = input.float(-100, title="CCI FDI Chop Short Threshold", group=FDI_Group + "CCI",maxval=0,tooltip = "Setting to 0 disables filtering on the downside")


// ─── Chande Momentum OScillator (CMO) ────────────────────────────────
CMO_length  = input.int(30, minval=1, title="CMO Length", group=FDI_Group + "CMO")
CMO_src     = input.source(close, "CMO Source", group=FDI_Group + "CMO")
CMO_FDI_chop_LongThreshold  = input.float(30, title="CMO FDI Chop Long Threshold", group=FDI_Group + "CMO",minval=0,tooltip = "Setting to 0 disables filtering on the upside")
CMO_FDI_chop_ShortThreshold = input.float(-30, title="CMO FDI Chop Short Threshold", group=FDI_Group + "CMO",maxval=0,tooltip = "Setting to 0 disables filtering on the downside")

// ─── Money Flow Index (MFI) ────────────────────────────────
MFI_length  = input.int(30, minval=1, title="MFI Length", group=FDI_Group + "MFI")
MFI_src     = input.source(hlc3, "MFI Source", group=FDI_Group + "MFI")
MFI_FDI_chop_LongThreshold  = input.float(55, title="MFI FDI Chop Long Threshold", group=FDI_Group + "MFI",minval=50,tooltip = "Setting to 50 disables filtering on the upside")
MFI_FDI_chop_ShortThreshold = input.float(45, title="MFI FDI Chop Short Threshold", group=FDI_Group + "MFI",maxval=50,tooltip = "Setting to 50 disables filtering on the downside")


// ─── FDI Filter ────────────────────────────────────────────────
i4_N = input.int(70, title="FDI Length",group = FDI_Group + "FDI Filter")
FDI_threshold = input.float(1.9,"FDI Chopping Threshold",step=0.01,group = FDI_Group + "FDI Filter",tooltip = "The usual implemetation measures ranging above 1.50 and trending below (with <= 1.3 - 1.35 being unsustainable trending), but you may change this depending on your lookback length.")
i4_S = input.source(ohlc4,"FDI Source",group = FDI_Group + "FDI Filter")

plotcandles = input.bool(true,"Color Candles",group = FDI_Group + "General Styling")
longColor = input(#00ffe5,"Long Condition Color",group = FDI_Group + "General Styling")
shortColor = input(#ff0055,"Short Condition Color",group = FDI_Group + "General Styling")

// Calculate the current FDI
i4_hh = ta.highest(i4_S, i4_N)
i4_ll = ta.lowest(i4_S, i4_N)

// Precompute the diff array for each i in [1..N]
var float[] diffs = array.new_float(i4_N)
for i = 0 to i4_N - 1
    val = (i4_S[i] - i4_ll) / (i4_hh - i4_ll)
    array.set(diffs, i, val)

// Calculate length as sum of sqrt of squared differences + (1/N)^2
float length = 0.0
for i = 0 to i4_N - 2
    diff_i = array.get(diffs, i)
    diff_ip1 = array.get(diffs, i + 1)
    length += math.sqrt(math.pow(diff_i - diff_ip1, 2) + math.pow(1.0 / i4_N, 2))

FDI = 1 + (math.log(length) + math.log(2)) / math.log(2 * i4_N)

// Define regime: chopping when FDI > threshold, otherwise trending
FDI_Chopping = FDI >= FDI_threshold


i4_rsi = ta.rsi(RSI_src,RSI_length)
i4_cci = ta.cci(CCI_src,CCI_length)
i4_cmo = ta.cmo(CMO_src,CMO_length)
i4_mfi = ta.mfi(MFI_src,MFI_length)

// ─── Signal Generation ────────────────────────────────────────────────
var int RSI_signal = 0
var int CCI_signal = 0
var int CMO_signal = 0
var int MFI_signal = 0

if barstate.isconfirmed
    if FDI_Chopping
        // In FDI chop regime simple midline crossing.
        RSI_signal := i4_rsi > 50 ? 1 : i4_rsi < 50 ? -1 : RSI_signal[1]
        CCI_signal := i4_cci > 0 ? 1 : i4_cci < 0 ? -1 : CCI_signal[1]
        CMO_signal := i4_cmo > 0 ? 1 : i4_cmo < 0 ? -1 : CMO_signal[1]
        MFI_signal := i4_mfi > 50 ? 1 : i4_mfi < 50 ? -1 : MFI_signal[1]
    else
        // In FDI chop regime, require the pierce of adjustable thresholds.
        RSI_signal := i4_rsi > RSI_FDI_chop_LongThreshold ? 1 : i4_rsi < RSI_FDI_chop_ShortThreshold ? -1 : RSI_signal[1]
        CCI_signal := i4_cci > CCI_FDI_chop_LongThreshold ? 1 : i4_cci < CCI_FDI_chop_ShortThreshold ? -1 : CCI_signal[1]
        CMO_signal := i4_cmo > CMO_FDI_chop_LongThreshold ? 1 : i4_cmo < CMO_FDI_chop_ShortThreshold ? -1 : CMO_signal[1]
        MFI_signal := i4_mfi > MFI_FDI_chop_LongThreshold ? 1 : i4_mfi < MFI_FDI_chop_ShortThreshold ? -1 : MFI_signal[1]

// ─── Combine Enabled Oscillator Signals ─────────────────────────────────
// Count how many oscillators are enabled
oscCount = (useRSI ? 1: 0) + (useCCI ? 1 : 0) + (useCMO ? 1 : 0) + (useMFI ? 1 : 0) 

// Persistent combined trend signal:  1 = long, -1 = short, 0 = no change/undefined
var int trendSignal = 0


sumSig = 0
if barstate.isconfirmed
    // 1) Compute the sum of all enabled oscillator signals
    sumSig += useCCI ? CCI_signal : 0
    sumSig += useCMO ? CMO_signal : 0
    sumSig += useMFI ? MFI_signal : 0
    sumSig += useRSI ? RSI_signal : 0


    // 2) If the count of enabled oscillators is ODD → sumSig cannot be zero,
    //    so trendSignal is simply the sign of sumSig (±1).
    if (oscCount % 2) == 1
        trendSignal := sumSig > 0 ? 1 : sumSig < 0 ? -1 : sumSig[1]
    else
        // 3) If the count is EVEN → we need to check for a “tie” (sumSig == 0).
        //    • If sumSig == 0, that means exactly half are +1 and half are –1.
        //      In that case, CONTINUE the previous trend: trendSignal[1].
        //    • Otherwise, take the sign of sumSig as usual.
        trendSignal := sumSig == 0 ? trendSignal[1] : (sumSig > 0 ? 1 : sumSig < 0 ? -1 : sumSig[1])


// ─── Visual Styling ─────────────────────────────────────────────────────
consensusStrength = oscCount > 0 ? sumSig / oscCount : 0
currentColor = trendSignal == 1 ? longColor : trendSignal == -1 ? shortColor : color.gray

indicator4_score = trendSignal



// ======================================== End of Indicator 4 ============================


// ======================================== Start of Indicator 5 ============================

//              ╔════════════════════════════════╗              //
//              ║      USER-DEFINED SETTINGS     ║              //
//              ╚════════════════════════════════╝              //

// Input Groups
var i5_group = "Indicator 5 - "
var string core_settings     = i5_group + "════════ Core Settings ════════"
var string fourier_settings  = i5_group + "════════ Fourier Settings ════════"
var string supertrend_settings = i5_group + "════════ Supertrend Settings ════════"
var string visual_settings   = i5_group + "════════ Visual Settings ════════"

// Tooltips
tooltip_source     = "Select the price data to analyze (Close, Open, High, Low, etc.)"
tooltip_period     = "Base period for Fourier transform calculations. Affects trend detection sensitivity."
tooltip_smooth     = "Smoothing period for the Fourier output. Higher values create smoother signals."
tooltip_weight     = "Weight for harmonic components. Higher values increase sensitivity to shorter trends."
tooltip_vol_len    = "Period for volatility calculations. Affects band width adaptability."
tooltip_vol_mult   = "Multiplier for volatility bands. Higher values create wider bands."
tooltip_vol_smooth = "Smoothing period for volatility. Higher values create more stable bands."
tooltip_bars       = "Enable/disable coloring of price bars based on the trend."
tooltip_signals    = "Show/hide trend change signals on the chart."
tooltip_bull_color = "Color for bullish signals and uptrends."
tooltip_bear_color = "Color for bearish signals and downtrends."

// Core Settings
i5_price_source = input.source(ohlc4, "Price Source", 
     group=core_settings, 
     tooltip=tooltip_source)
     
// Fourier Settings
fft_period = input.int(84, "Base Period", 
     minval=4, 
     group=fourier_settings, 
     tooltip=tooltip_period)
fft_smooth = input.int(14, "Smoothing", 
     minval=1, 
     group=fourier_settings, 
     tooltip=tooltip_smooth)
harmonic_weight = input.float(0.2, "Harmonic Weight", 
     minval=0, maxval=1, step=0.1, 
     group=fourier_settings, 
     tooltip=tooltip_weight)

// Volatility Settings
i5_vol_length = input.int(76, "Volatility Length", 
     minval=1, 
     group=supertrend_settings, 
     tooltip=tooltip_vol_len)
i5_vol_mult = input.float(2.0, "Volatility Multiplier", 
     minval=0.1, step=0.1, 
     group=supertrend_settings, 
     tooltip=tooltip_vol_mult)
i5_vol_smooth = input.int(28, "Volatility Smoothing", 
     minval=1, 
     group=supertrend_settings, 
     tooltip=tooltip_vol_smooth)

// Visual Settings
i5_bull_color = input.color(#00ffaa, "Bullish Color", 
     group=visual_settings, 
     tooltip=tooltip_bull_color)
i5_bear_color = input.color(#ff0000, "Bearish Color", 
     group=visual_settings, 
     tooltip=tooltip_bear_color)
i5_enable_bars = input.bool(true, "Color Price Bars", 
     group=visual_settings, 
     tooltip=tooltip_bars)
i5_show_signals = input.bool(true, "Show Signals", 
     group=visual_settings, 
     tooltip=tooltip_signals)

//              ╔════════════════════════════════╗              //
//              ║          CALCULATIONS          ║              //
//              ╚════════════════════════════════╝              //

// FFT Trend Function
get_fft_trend(src, len) =>
    wave1 = ta.ema(src, len)
    wave2 = ta.ema(src, math.floor(len/2))
    wave3 = ta.ema(src, math.floor(len/3))
    trend = wave1 + harmonic_weight * (wave2 - wave1) + harmonic_weight * harmonic_weight * (wave3 - wave2)
    trend

// Volatility Function
get_adaptive_volatility() =>
    atr = ta.atr(i5_vol_length)
    std = ta.stdev(close, i5_vol_length)
    vol = math.avg(atr, std)
    vol

// Main calculations
fft_trend = get_fft_trend(i5_price_source, fft_period)
fft_trend := ta.ema(fft_trend, fft_smooth)

i5_volatility = get_adaptive_volatility()
i5_volatility := ta.ema(i5_volatility, i5_vol_smooth)

i5_upper_band = fft_trend + i5_volatility * i5_vol_mult
i5_lower_band = fft_trend - i5_volatility * i5_vol_mult

//              ╔════════════════════════════════╗              //
//              ║        SIGNAL GENERATION       ║              //
//              ╚════════════════════════════════╝              //

// Trend determination
var int i5_trend = 0
var float i5_trend_band = na

if close > i5_trend_band and close > fft_trend
    i5_trend := 1
    i5_trend_band := i5_lower_band
else if close < i5_trend_band and close < fft_trend
    i5_trend := -1
    i5_trend_band := i5_upper_band
else
    i5_trend_band := i5_trend == 1 ? i5_lower_band : i5_trend == -1 ? i5_upper_band : fft_trend

// Track trend changes
var i5_prev_trend = 0
i5_trend_changed = i5_trend != i5_prev_trend
i5_prev_trend := i5_trend

indicator5_score = i5_trend


//              ╔════════════════════════════════╗              //
//              ║         VISUALIZATION          ║              //
//              ╚════════════════════════════════╝              //

// Transparency values
i5_transparency_bullish = 70
i5_transparency_bearish = 95


// Bar coloring
var color i5_bar_color = #ffffff
if i5_trend == 1
    i5_bar_color := i5_bull_color
else if i5_trend == -1
    i5_bar_color := i5_bear_color







//              ╔════════════════════════════════╗              //
//              ║             ALERTS             ║              //
//              ╚════════════════════════════════╝              //


